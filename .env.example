# AETHER local development environment template

# API runtime
AETHER_API_BASE_URL=http://localhost:5000
AETHER_TENANT=acme

# Azure OpenAI (required for DSPy nightly optimizer diagnostics)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Supabase (required for optimizer persistence)
SUPABASE_URL=
SUPABASE_KEY=
